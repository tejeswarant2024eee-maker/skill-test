      "id": "e8d665b5-4eff-4fc3-8ea7-022755ce57f6",
      "cell_type": "code",
      "source": "# List of exam scores of 20 students\nscores = [78, 45, 89, 66, 52, 91, 34, 73, 60, 48,\n          55, 82, 69, 41, 95, 58, 77, 62, 39, 84]\n\n# 1. Overall class performance\naverage_score = sum(scores) / len(scores)\nhighest_score = max(scores)\nlowest_score = min(scores)\n\nprint(\"Overall Class Performance\")\nprint(\"Average Score:\", average_score)\nprint(\"Highest Score:\", highest_score)\nprint(\"Lowest Score:\", lowest_score)\n\n# 2. Pass/Fail classification\nprint(\"\\nPass/Fail Classification (Pass mark = 50)\")\nfor i, score in enumerate(scores, start=1):\n    if score >= 50:\n        print(f\"Student {i}: {score} - Pass\")\n    else:\n        print(f\"Student {i}: {score} - Fail\")\n\n# 3. Grading using predefined thresholds\nprint(\"\\nGrades\")\n\ndef get_grade(score):\n    if score >= 90:\n        return \"A\"\n    elif score >= 75:\n        return \"B\"\n    elif score >= 60:\n        return \"C\"\n    elif score >= 50:\n        return \"D\"\n    else:\n        return \"F\"\n\nfor i, score in enumerate(scores, start=1):\n    grade = get_grade(score)\n    print(f\"Student {i}: Score = {score}, Grade = {grade}\")",
