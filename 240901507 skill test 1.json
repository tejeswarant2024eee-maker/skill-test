      "id": "68d13f9f-dcb6-4b2a-a40a-213abdbccbed",
      "cell_type": "code",
      "source": "import numpy as np\n\n# Input values\nR = float(input(\"Enter Resistance (Ohms): \"))\nL = float(input(\"Enter Inductance (H): \"))\nC = float(input(\"Enter Capacitance (F): \"))\nf = float(input(\"Enter Frequency (Hz): \"))\n\n# Angular frequency\nomega = 2 * np.pi * f\n\n# Impedance calculations\nZ_R = R\nZ_L = 1j * omega * L\nZ_C = 1 / (1j * omega * C)\n\nprint(\"\\nImpedance of Components:\")\nprint(\"Resistor Impedance:\", Z_R)\nprint(\"Inductor Impedance:\", Z_L)\nprint(\"Capacitor Impedance:\", Z_C)\n\n# Series impedance\nZ_series = Z_R + Z_L + Z_C\n\n# Parallel impedance\nZ_parallel = 1 / (1/Z_R + 1/Z_L + 1/Z_C)\n\nprint(\"\\nTotal Impedance (Series):\", Z_series)\nprint(\"Total Impedance (Parallel):\", Z_parallel)",
      "metadata": {
        "trusted": true
      },
