      "id": "f4b00cbe-3968-4a3f-b839-a6d64733fbf1",
      "cell_type": "code",
      "source": "import numpy as np\nimport matplotlib.pyplot as plt\n\n# Generate marks for 30 students (rows) and 3 subjects (columns)\n# Subjects: Math, Science, English\nnp.random.seed(0)\nmarks = np.random.randint(40, 100, size=(30, 3))\n\nsubjects = [\"Math\", \"Science\", \"English\"]\n\nprint(\"Marks of Students:\\n\")\nprint(marks)\n\n# Subject-wise statistics\navg_subject = np.mean(marks, axis=0)\nmax_subject = np.max(marks, axis=0)\nmin_subject = np.min(marks, axis=0)\n\nprint(\"\\nSubject-wise Statistics:\")\nfor i in range(3):\n    print(subjects[i])\n    print(\"Average:\", avg_subject[i])\n    print(\"Highest:\", max_subject[i])\n    print(\"Lowest:\", min_subject[i])\n    print()\n\n# Total and average marks per student\ntotal_marks = np.sum(marks, axis=1)\navg_marks = np.mean(marks, axis=1)\n\n# Identify top-performing student\ntop_student = np.argmax(total_marks)\n\nprint(\"Top Performing Student (Index):\", top_student)\nprint(\"Total Marks:\", total_marks[top_student])\nprint(\"Average Marks:\", avg_marks[top_student])\n\n# Visualization\nplt.figure(figsize=(10,4))\n\nfor i in range(3):\n    plt.subplot(1,3,i+1)\n    plt.hist(marks[:,i], bins=5, color='skyblue', edgecolor='black')\n    plt.title(subjects[i])\n    plt.xlabel(\"Marks\")\n    plt.ylabel(\"Number of Students\")\n\nplt.tight_layout()\nplt.show()",
